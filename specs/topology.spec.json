{
  "schemaVersion": 5,
  "kind": "sdkwork.app.topology",
  "appId": "sdkwork-community",
  "archetype": "application-http-gateway",
  "profileRoot": "configs/topology",
  "profilePattern": "{deploymentProfile}.{environment}.env",
  "vocabulary": {
    "deploymentProfile": {
      "allowed": [
        "standalone",
        "cloud"
      ]
    },
    "environment": {
      "allowed": [
        "development",
        "production"
      ]
    }
  },
  "defaults": {
    "developmentProfileId": "standalone.development",
    "productionProfileId": "cloud.production",
    "gatewayBind": "0.0.0.0:18094",
    "desktopBuildProfileId": "standalone.production"
  },
  "profileFiles": {
    "standalone.development": "configs/topology/standalone.development.env",
    "standalone.production": "configs/topology/standalone.production.env",
    "cloud.production": "configs/topology/cloud.production.env",
    "cloud.development": "configs/topology/cloud.development.env"
  },
  "envKeys": {
    "deploymentProfile": "SDKWORK_COMMUNITY_DEPLOYMENT_PROFILE",
    "environment": "SDKWORK_COMMUNITY_ENVIRONMENT",
    "profileId": "SDKWORK_COMMUNITY_PROFILE_ID",
    "standaloneGatewayBind": "COMMUNITY_API_BIND",
    "apiGatewayBaseUrl": "SDKWORK_COMMUNITY_PLATFORM_API_GATEWAY_HTTP_URL",
    "clientApiGatewayBaseUrl": "VITE_SDKWORK_COMMUNITY_PLATFORM_API_GATEWAY_HTTP_URL"
  },
  "surfaces": {
    "application.public-ingress": {
      "connectivityPlane": "application",
      "protocols": [
        "http"
      ],
      "bindEnv": "COMMUNITY_API_BIND",
      "httpUrlEnv": "SDKWORK_COMMUNITY_APPLICATION_PUBLIC_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_COMMUNITY_APPLICATION_PUBLIC_HTTP_URL"
    },
    "platform.api-gateway": {
      "connectivityPlane": "platform",
      "protocols": [
        "http"
      ],
      "httpUrlEnv": "SDKWORK_COMMUNITY_PLATFORM_API_GATEWAY_HTTP_URL",
      "clientHttpEnv": "VITE_SDKWORK_COMMUNITY_PLATFORM_API_GATEWAY_HTTP_URL"
    }
  },
  "database": {
    "appPrefix": "SDKWORK_COMMUNITY"
  },
  "components": {
    "applicationServer": {
      "crate": "sdkwork-community-standalone-gateway",
      "binary": "sdkwork-community-standalone-gateway"
    }
  },
  "deploymentProfiles": {
    "standalone": {
      "serviceLayout": "unified-process",
      "runtimeTarget": "browser",
      "connectivity": {
        "communityApi": {
          "bind": "0.0.0.0:18094",
          "env": "COMMUNITY_API_BIND"
        }
      },
      "surfaces": {
        "pc": {
          "devPort": 3000,
          "appApiBaseUrl": "http://localhost:18094/app/v3/api",
          "openApiBaseUrl": "http://localhost:18094/community/v3/api"
        },
        "h5": {
          "devPort": 3001,
          "appApiBaseUrl": "http://localhost:18094/app/v3/api",
          "openApiBaseUrl": "http://localhost:18094/community/v3/api"
        }
      }
    },
    "cloud": {
      "serviceLayout": "split-services",
      "runtimeTarget": "browser",
      "connectivity": {
        "communityApi": {
          "gatewayPath": "/community"
        }
      }
    }
  },
  "cloudPublicHosts": {
    "platform.api-gateway": {
      "httpHost": "api.sdkwork.com"
    }
  },
  "orchestration": {
    "profiles": {
      "standalone.development": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-community-standalone-gateway",
            "binary": "sdkwork-community-standalone-gateway",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "standalone.production": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-community-standalone-gateway",
            "binary": "sdkwork-community-standalone-gateway",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress"
        ]
      },
      "cloud.development": {
        "processes": [],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      },
      "cloud.production": {
        "processes": [
          {
            "id": "application.public-ingress",
            "crate": "sdkwork-community-standalone-gateway",
            "binary": "sdkwork-community-standalone-gateway",
            "required": true,
            "role": "api-standalone-gateway"
          }
        ],
        "healthSurfaces": [
          "application.public-ingress",
          "platform.api-gateway"
        ]
      }
    }
  },
  "packaging": {
    "cloudConfigFiles": [],
    "targets": [
      {
        "id": "container-noarch-cloud-container-config-bundle-tar-gz",
        "profile": "container",
        "platform": "container",
        "architecture": "noarch",
        "formats": [
          "tar.gz"
        ],
        "runner": "ubuntu-24.04",
        "outputGlob": "dist/cloud-config/sdkwork-community-api-gateway-config-*.tar.gz",
        "deploymentProfile": "cloud",
        "runtimeTarget": "container",
        "variant": "config-bundle"
      }
    ]
  }
}
