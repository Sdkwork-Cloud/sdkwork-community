{
  "schemaVersion": 1,
  "kind": "sdkwork.component.spec",
  "component": {
    "name": "sdkwork-community-sdk",
    "displayName": "SDKWork Community Open API SDK",
    "version": "0.1.0",
    "type": "sdk-family",
    "root": "sdkwork-community/sdks/sdkwork-community-sdk",
    "domain": "community",
    "capability": "community",
    "status": "standardized",
    "languages": [
      "typescript"
    ],
    "generated": true,
    "private": false,
    "manifests": [
      ".sdkwork-assembly.json",
      "sdk-manifest.json"
    ]
  },
  "canonicalSpecs": [
    {
      "file": "API_SPEC.md",
      "path": "../../../../../javasource/spring-ai-plus/spring-ai-plus-business/specs/API_SPEC.md",
      "purpose": "HTTP/OpenAPI and generated SDK contract rules."
    },
    {
      "file": "SDK_SPEC.md",
      "path": "../../../../../javasource/spring-ai-plus/spring-ai-plus-business/specs/SDK_SPEC.md",
      "purpose": "SDK generation, SDK dependency, and SDK integration rules."
    },
    {
      "file": "SDK_WORKSPACE_GENERATION_SPEC.md",
      "path": "../../../../../javasource/spring-ai-plus/spring-ai-plus-business/specs/SDK_WORKSPACE_GENERATION_SPEC.md",
      "purpose": "SDK workspace and authority naming rules."
    }
  ],
  "contracts": {
    "apiAuthority": {
      "name": "sdkwork-community.open",
      "prefix": "/community/v3/api",
      "authorityOpenApi": "../../generated/openapi/community-open-api.openapi.json",
      "owner": "sdkwork-community"
    },
    "sdkDependencies": []
  },
  "verification": {
    "commands": [
      "node tools/community_sdk_generate.mjs --check",
      "node sdks/sdkwork-community-sdk/bin/generate-sdk.mjs"
    ]
  }
}
