{
  "name": "sdkwork-community-workspace",
  "private": true,
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "stop": "pnpm exec sdkwork-app stop",
    "dev": "pnpm dev:standalone",
    "build": "pnpm exec sdkwork-app build",
    "test": "pnpm exec sdkwork-app test",
    "check": "pnpm exec sdkwork-app check",
    "verify": "pnpm exec sdkwork-app verify",
    "clean": "pnpm exec sdkwork-app clean",
    "typecheck": "tsc --noEmit",
    "api:materialize": "node tools/community_openapi_export.mjs",
    "api:materialize:check": "node tools/community_openapi_export.mjs --check",
    "api:check": "pnpm api:materialize:check",
    "sdk:generate": "node tools/community_sdk_generate.mjs",
    "sdk:generate:check": "node tools/community_sdk_generate.mjs --check",
    "sdk:check": "pnpm sdk:generate:check",
    "gateway:run": "cargo run -p sdkwork-community-standalone-gateway",
    "gateway:validate": "cargo check -p sdkwork-community-standalone-gateway",
    "dev:browser": "pnpm dev:browser:postgres:standalone",
    "dev:desktop": "pnpm dev:desktop:postgres:standalone",
    "build:browser": "pnpm --filter sdkwork-community-h5-workspace build",
    "build:desktop": "pnpm --filter sdkwork-community-pc-workspace build",
    "test:browser": "pnpm --filter sdkwork-community-h5-workspace test",
    "test:desktop": "pnpm --filter sdkwork-community-pc-workspace test",
    "dev:flutter-android": "pnpm exec sdkwork-app dev --runtime-target flutter-android --deployment-profile standalone",
    "build:flutter-android": "cd apps/sdkwork-community-flutter-mobile && flutter build apk",
    "build:flutter-ios": "cd apps/sdkwork-community-flutter-mobile && flutter build ios",
    "test:flutter": "cd apps/sdkwork-community-flutter-mobile && flutter test && flutter analyze",
    "test:node": "node --test scripts/*.test.mjs sdks/test/*.test.mjs sdks/sdkwork-community-sdk/tests/*.test.mjs sdks/sdkwork-community-app-sdk/tests/*.test.mjs sdks/sdkwork-community-backend-sdk/tests/*.test.mjs",
    "test:vitest": "vitest run --config vitest.config.ts --configLoader native --pool vmThreads",
    "db:materialize:contract": "node ../sdkwork-specs/tools/materialize-database-contract-from-baseline.mjs --root . --baseline database/ddl/baseline/postgres/0001_community_baseline.sql --module-id community --owner community-platform --prefixes community_ --engines postgres",
    "db:validate": "node ../sdkwork-specs/tools/check-database-framework-standard.mjs --root .",
    "db:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan",
    "db:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init",
    "db:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate",
    "db:seed": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . seed",
    "db:status": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . status",
    "db:drift": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift",
    "db:drift:check": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . drift-check",
    "db:bootstrap": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . bootstrap",
    "db:postgres:plan": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . plan --engine postgres",
    "db:postgres:init": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . init --engine postgres",
    "db:postgres:migrate": "cargo run --manifest-path ../sdkwork-database/Cargo.toml -p sdkwork-database-cli -- --app-root . migrate --engine postgres",
    "test:contract:database": "pnpm db:validate",
    "check:api-envelope": "node ../sdkwork-specs/tools/check-api-response-envelope.mjs --workspace .",
    "check:pnpm-script-standard": "node ../sdkwork-specs/tools/check-pnpm-script-standard.mjs --root .",
    "check:app-composition": "node ../sdkwork-specs/tools/verify-repo.mjs --root .",
    "deploy:validate": "node ../sdkwork-specs/tools/check-deploy-standard.mjs",
    "deploy:plan": "node ../sdkwork-specs/tools/deployctl.mjs plan --root .",
    "workflow:prepare-ci-dependencies": "node scripts/prepare-ci-dependencies.mjs",
    "topology:validate": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs validate --root . --spec specs/topology.spec.json",
    "topology:plan": "node ../sdkwork-app-topology/scripts/sdkwork-topology.mjs plan --root . --spec specs/topology.spec.json",
    "api:assembly:materialize": "node ../sdkwork-specs/tools/materialize-api-assembly.mjs --root .",
    "api:assembly:validate": "node ../sdkwork-specs/tools/validate-api-assembly.mjs --root .",
    "_sdkwork:build": "pnpm build:desktop",
    "_sdkwork:test": "pnpm test:node && pnpm test:vitest && cargo test --workspace",
    "_sdkwork:check": "pnpm typecheck && pnpm api:check && pnpm sdk:check && pnpm db:validate && pnpm check:api-envelope && pnpm check:pnpm-script-standard && pnpm deploy:validate",
    "_sdkwork:verify": "pnpm check && pnpm test:node && pnpm test:vitest && cargo test --workspace && cargo clippy --workspace --tests -- -D warnings && pnpm run check:app-composition",
    "_sdkwork:clean": "node scripts/clean-artifacts.mjs",
    "dev:standalone": "pnpm exec sdkwork-app dev --deployment-profile standalone",
    "dev:cloud": "pnpm exec sdkwork-app dev --deployment-profile cloud",
    "deploy:plan:standalone": "pnpm exec sdkwork-app deploy:plan --deployment-profile standalone",
    "deploy:plan:cloud": "pnpm exec sdkwork-app deploy:plan --deployment-profile cloud",
    "deploy:validate:standalone": "pnpm exec sdkwork-app deploy:validate --deployment-profile standalone",
    "deploy:validate:cloud": "pnpm exec sdkwork-app deploy:validate --deployment-profile cloud",
    "dev:browser:postgres:standalone": "pnpm exec sdkwork-app dev --runtime-target browser --deployment-profile standalone",
    "dev:browser:sqlite:standalone": "node scripts/community-dev.mjs --target browser --deployment-profile standalone --database sqlite",
    "dev:desktop:postgres:standalone": "pnpm exec sdkwork-app dev --runtime-target desktop --deployment-profile standalone",
    "dev:desktop:sqlite:standalone": "node scripts/community-dev.mjs --target desktop --deployment-profile standalone --database sqlite"
  },
  "devDependencies": {
    "@sdkwork/ui-pc-react": "workspace:*",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^29.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2",
    "@sdkwork/app-topology": "workspace:*"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  }
}
